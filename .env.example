APP_ENV=local
APP_SECRET_KEY=change_me
APP_BASE_URL=http://localhost:8080
DATABASE_URL=postgresql+psycopg://hipodromo:hipodromo@db:5432/hipodromo_tips

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

LLM_PROVIDER=mock
LLM_MODEL=mock-model
LLM_BASE_URL=
LLM_API_KEY=
SECONDARY_LLM_PROVIDER=
SECONDARY_LLM_MODEL=
SECONDARY_LLM_BASE_URL=
SECONDARY_LLM_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=administracion@hipodromos.org
EMAIL_RECIPIENTS=

GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
OUTPUT_STORAGE_MODE=local

CONSENSUS_PICK_1_POINTS=3
CONSENSUS_PICK_2_POINTS=2
CONSENSUS_PICK_3_POINTS=1

# Plantillas Excel (relativas a templates_excel/)
TIPS_TEMPLATE_FILENAME=Tips _Ejemplo.xlsx
CUADRO_TEMPLATE_FILENAME=Cuadro_Pronosticos_Ejemplo.xlsx

# Cuadro acumulativo (archivo corporativo PRONOS; ver docs/runbook_sharepoint.md)
PRONOS_FILE_PATH=data/PRONOS 2026.xlsx
PRONOS_BACKUP_DIR=data/backups
# Patrón del nombre de hoja por jornada. Admite {dd} {mm} {date} {venue}.
# El archivo corporativo real usa PRO_DD_MM.
CUADRO_SHEET_NAME_PATTERN=PRO_{dd}_{mm}

# Rate limit del login
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
